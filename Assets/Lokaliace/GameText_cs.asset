  - m_Id: 176675872501760
    m_Localized: "V\xFDdaje"
    m_Metadata:
      m_Items: []
  - m_Id: 176859956310016
    m_Localized: Dluh
    m_Metadata:
      m_Items: []
  - m_Id: 177202203127808
    m_Localized: "Spravedlnost a po\u0159\xE1dek"
    m_Metadata:
      m_Items: []
  - m_Id: 177615392403456
    m_Localized: "Zahrani\u010Dni politika"
    m_Metadata:
      m_Items: []
  - m_Id: 177823090143232
    m_Localized: "Socialn\xED a zdravotni"
